# Supabase (Prompt 2 onwards)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API (Prompts 6, 7, 11 — generator, examiner, assistant)
ANTHROPIC_API_KEY=

# Stripe (Prompt 12)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Monthly price ids created in the Stripe dashboard (amounts must match lib/pricing.ts)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_LAUNCH=
STRIPE_PRICE_GROWTH=
# App base URL for checkout/portal redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin console (Prompt 14 — comma-separated allowlist; empty blocks everyone)
ADMIN_EMAILS=

# Scheduled jobs (Prompt 9 — the uprating re-check trigger; bearer token for /api/jobs/*)
JOBS_SECRET=

# Resend (Prompt 13)
RESEND_API_KEY=

# PostHog (optional in dev)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta Pixel + Conversions API (ads measurement — optional; everything no-ops without them)
# Pixel id from Meta Events Manager; token from Events Manager → Settings → Conversions API
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=
